# Supabase — Project Settings → API Keys
# ⚠️ Utilise la "Project URL" (ex. https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL publique de l'app (OAuth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role — serveur uniquement (suppression de comptes admin)
SUPABASE_SERVICE_ROLE_KEY=

# football-data.org — scores live, minute, statut CDM 2026 (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=

# odds-api.io — cotes 1N2 (https://odds-api.io) — doc : /v3/events?status=live + /v3/odds/multi
ODDS_API_KEY=
# Optionnel : bookmakers CSV, slug ligue CDM si auto-détection échoue
# ODDS_API_BOOKMAKERS=Bet365,Unibet
# ODDS_API_WC_LEAGUE_SLUG=international-world-cup
# Optionnel : secret pour GET /api/cron/sync-football-data (header Authorization: Bearer …)
CRON_SECRET=

# Gazette du Match — au moins une clé (gratuit)
# Groq : https://console.groq.com/keys
GROQ_API_KEY=gsk...
# Gemini : https://aistudio.google.com/apikey
GEMINI_API_KEY=
